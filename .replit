modules = ["go-1.25"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd callsync-server && go build -mod=vendor -o callsync_server . && ./callsync_server"
waitForPort = 8080

[[ports]]
localPort = 8080
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["sh", "-c", "cd callsync-server && go build -mod=vendor -o callsync_server . && ./callsync_server"]
